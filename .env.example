# ==============================
# MODE 1: WEBHOOK / GITHUB ACTIONS
# Chạy theo lịch, không cần bot online 24/7.
# ==============================
DISCORD_WEBHOOK_URL=optional_fallback_webhook_here
EPIC_DISCORD_WEBHOOK_URL=your_epic_channel_webhook_here
STEAM_DISCORD_WEBHOOK_URL=your_steam_channel_webhook_here

ENABLE_EPIC=true
ENABLE_STEAM=true
ENABLE_FREE_ALERTS=true
ENABLE_UPCOMING_ALERTS=true
ENABLE_EVENT_ALERTS=true

SALE_ALERTS_ENABLED=true
SEND_SALE_DETAILS_TO_DISCORD=true
MIN_SALE_DISCOUNT_PERCENT=80
MAX_SALE_ALERTS_PER_PLATFORM=5
STEAM_PAGES_TO_SCAN=3

# Cấu hình tiền tệ mong muốn hiển thị: VN (Việt Nam Đồng ₫) hoặc US (Đô la Mỹ $)
# Nếu chọn US, bộ lọc giá tối đa MAX_SALE_PRICE cũng sẽ tính theo USD
CURRENCY_LOCALE=VN

# Bộ lọc nâng cao theo nhu cầu cá nhân
# Giá tối đa của deal sale muốn nhận thông báo (ví dụ: 150000 VNĐ hoặc 10 USD)
MAX_SALE_PRICE=

# Thể loại game muốn nhận (ngăn cách bằng dấu phẩy, ví dụ: Action, RPG, Shooter)
PREFERRED_GENRES=

# Thể loại game muốn loại trừ (ví dụ: Hentai, Anime)
EXCLUDED_GENRES=

# Cấu hình mở rộng nâng cao
# Đặt ngôn ngữ tin nhắn gửi lên Discord và log console: vi (Tiếng Việt) hoặc en (Tiếng Anh)
MESSAGE_LOCALE=vi

# Đặt Role ID cần tag/mention khi gửi tin nhắn Discord (Ví dụ: @everyone, @here, hoặc <@&role_id>)
DISCORD_MENTION_ROLE=

# ==============================
# MODE 2: DISCORD BOT APP / TOKEN
# Dùng khi muốn bot online và nhận lệnh Discord.
# Cần máy/VPS/cloud chạy liên tục.
# ==============================
DISCORD_BOT_TOKEN=
DISCORD_BOT_PREFIX=!
DISCORD_BOT_COOLDOWN_SEC=5
DISCORD_BOT_FREE_EVENT_ONLY=false
